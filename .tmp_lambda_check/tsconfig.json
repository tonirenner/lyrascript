{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "rootDir": "..",
    "outDir": "out",
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "../language/src/core/**/*.ts",
    "../language/src/library/**/*.ts"
  ]
}
