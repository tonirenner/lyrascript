class Program {
    public render(): VNode {
        let items: Array<number> = [1, 2, 3];
        items.push(4);

        let sum: number = 0;

        foreach (item in items) {
            sum = sum + item;
        }

        return vdom
            <div>
                <h1>Arrays</h1>
                <p>length = {items.length()}</p>
                <p>third item = {items[2]}</p>
                <p>sum = {sum}</p>
            </div>;
    }
}
