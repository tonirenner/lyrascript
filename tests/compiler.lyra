class Test {
    value: number;
    name: string = "Test ndkasd asd asdaksdnas dasdkasjd adsasdasodadsoad adoasd";

    constructor(v: number) {
        this.value = v;
    }

    public getNeg(): number {
        let value = this.value;
        return -value;
    }
}

let t = new Test(10);
let result = t.getNeg() + 5;

